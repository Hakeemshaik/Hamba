# Copy this file to ".env" and fill in your keys to switch on the cloud database.
# Leave it empty / unset and the app runs entirely on the device (local storage).
# Anything starting with VITE_ is bundled into the public frontend, so ONLY put
# public keys here. The Supabase anon key is safe; never put a secret key here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
